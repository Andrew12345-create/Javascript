<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rivor Cars</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #2d2d2d;
        }
        header {
            background-color: #2d2d2d;
            color: #fff;
            padding: 1rem;
            text-align: center;
        }
        nav ul {
            list-style: none;
            padding: 0;
        }
        nav ul li {
            display: inline;
            margin-right: 1rem;
        }
        nav ul li a {
            color: #fff;
            text-decoration: none;
        }
        main {
            padding: 2rem;
        }
        .hero {
            background-color: #333;
            color: #fff;
            padding: 2rem;
            text-align: center;
        }
        .hero h2 {
            margin: 0;
        }
        .content {
            display: flex;
            justify-content: space-around;
            margin-top: 2rem;
        }
        .content .card {
            background-color: #fff;
            padding: 1rem;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            width: 30%;
        }
        footer {
            background-color: #000;
            color: #fff;
            text-align: center;
            padding: 1rem;
            position: fixed;
            width: 100%;
            bottom: 0;
        }
    </style>
</head>
<body>
    <header>
        <h1>Rivor Cars</h1>
        <nav>
            <ul>
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#services">Services</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>
    <main>
        <section class="hero">
            <h2>Welcome to Rivor Cars</h2>
            <p>Your dream car awaits you.</p>
        </section>
        <section class="content">
            <div class="card">
                <h3>Card 1</h3>
                <p>Some content for card 1.</p>
            </div>
            <div class="card">
                <h3>Card 2</h3>
                <p>Some content for card 2.</p>
            </div>
            <div class="card">
                <h3>Card 3</h3>
                <p>Some content for card 3.</p>
            </div>
        </section>
    </main>
    <footer>
        <p>&copy; 2023 Rivor Cars. All rights reserved.</p>
    </footer>
